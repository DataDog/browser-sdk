{
  "name": "@datadog/js-core",
  "version": "0.0.2",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/DataDog/browser-sdk/issues"
  },
  "sideEffects": false,
  "exports": {
    "./time": {
      "import": "./esm/time.js",
      "require": "./cjs/time.js",
      "types": "./cjs/time.d.ts"
    }
  },
  "files": [
    "cjs",
    "esm",
    "src",
    "time",
    "!src/**/*.spec.ts",
    "!src/**/*.specHelper.ts"
  ],
  "scripts": {
    "build": "node ../../scripts/build/build-package.ts --modules --esm-type-module",
    "prepack": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/browser-sdk.git",
    "directory": "packages/js-core"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
