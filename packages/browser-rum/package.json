{
  "name": "@datadog/browser-rum",
  "version": "7.6.1",
  "license": "Apache-2.0",
  "main": "cjs/entries/main.js",
  "module": "esm/entries/main.mjs",
  "types": "cjs/entries/main.d.ts",
  "files": [
    "bundle/**/*.js",
    "cjs",
    "esm",
    "src",
    "internal",
    "internal-synthetics",
    "!src/**/*.spec.ts",
    "!src/**/*.specHelper.ts"
  ],
  "scripts": {
    "build": "node ../../scripts/build/build-package.ts --modules --bundle datadog-rum.js",
    "build:bundle": "node ../../scripts/build/build-package.ts --bundle datadog-rum.js",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@datadog/browser-core": "7.6.1",
    "@datadog/browser-rum-core": "7.6.1",
    "@datadog/js-core": "0.0.7"
  },
  "peerDependencies": {
    "@datadog/browser-logs": "7.6.1"
  },
  "peerDependenciesMeta": {
    "@datadog/browser-logs": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/browser-sdk.git",
    "directory": "packages/browser-rum"
  },
  "devDependencies": {
    "@datadog/browser-worker": "7.6.1",
    "pako": "3.0.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
