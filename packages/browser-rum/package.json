{
  "name": "@datadog/browser-rum",
  "version": "7.2.0",
  "license": "Apache-2.0",
  "main": "cjs/entries/main.js",
  "module": "esm/entries/main.js",
  "types": "cjs/entries/main.d.ts",
  "files": [
    "bundle/**/*.js",
    "cjs",
    "esm",
    "src",
    "internal",
    "internal-synthetics",
    "!src/**/*.spec.ts",
    "!src/**/*.specHelper.ts"
  ],
  "scripts": {
    "build": "node ../../scripts/build/build-package.ts --modules --bundle datadog-rum.js",
    "build:bundle": "node ../../scripts/build/build-package.ts --bundle datadog-rum.js",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@datadog/browser-core": "7.2.0",
    "@datadog/browser-rum-core": "7.2.0",
    "@datadog/js-core": "0.0.1"
  },
  "peerDependencies": {
    "@datadog/browser-logs": "7.2.0"
  },
  "peerDependenciesMeta": {
    "@datadog/browser-logs": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/browser-sdk.git",
    "directory": "packages/browser-rum"
  },
  "devDependencies": {
    "@types/pako": "2.0.4",
    "pako": "2.1.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/DataDog/browser-sdk",
  "bugs": {
    "url": "https://github.com/DataDog/browser-sdk/issues"
  }
}