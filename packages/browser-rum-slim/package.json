{
  "name": "@openobserve/browser-rum-slim",
  "version": "7.3.0",
  "license": "Apache-2.0",
  "main": "cjs/entries/main.js",
  "module": "esm/entries/main.mjs",
  "types": "cjs/entries/main.d.ts",
  "files": [
    "bundle/**/*.js",
    "cjs",
    "esm",
    "src",
    "!src/**/*.spec.ts",
    "!src/**/*.specHelper.ts"
  ],
  "scripts": {
    "build": "node ../../scripts/build/build-package.ts --modules --bundle datadog-rum-slim.js",
    "build:bundle": "node ../../scripts/build/build-package.ts --bundle datadog-rum-slim.js",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@openobserve/browser-core": "7.3.0",
    "@openobserve/browser-rum-core": "7.3.0"
  },
  "peerDependencies": {
    "@openobserve/browser-logs": "7.3.0"
  },
  "peerDependenciesMeta": {
    "@openobserve/browser-logs": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/browser-sdk.git",
    "directory": "packages/browser-rum-slim"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "publishConfig": {
    "access": "public"
  }
}
