{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "module": "es2020",
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./esm",
    "paths": {}
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./src/**/*.spec.ts"]
}
