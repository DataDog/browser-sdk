  },
  "peerDependencies": {
    "@datadog/browser-logs": "6.32.0"
  },
  "peerDependenciesMeta": {
    "@datadog/browser-logs": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/browser-sdk.git",
    "directory": "packages/rum"
  },
  "devDependencies": {
    "@types/pako": "2.0.4",
    "pako": "2.1.0"
  },
  "volta": {
    "extends": "../../package.json"
  },
